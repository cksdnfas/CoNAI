{
  "name": "conai",
  "version": "26.5.23",
  "description": "React-based image viewer and manager for ComfyUI",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "concurrently --raw --kill-others \"npm run dev:shared\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:shared": "cd shared && npm run watch",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "ensure:deps": "node scripts/ensure-workspace-dependencies.js",
    "build": "npm run ensure:deps && npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "npm run ensure:deps && cd shared && npm run build",
    "build:frontend": "npm run ensure:deps && cd frontend && npm run build",
    "build:backend": "npm run ensure:deps && cd backend && npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "validate:metadata": "cd backend && npm run validate:metadata",
    "build:integrated": "npm run ensure:deps && node scripts/build-integrated.js",
    "build:bundle": "node scripts/build-bundle.js",
    "build:portable": "node scripts/build-portable.js",
    "build:docker": "node scripts/build-docker.js",
    "build:sea": "node scripts/build-sea.js",
    "build:full": "npm run build:integrated && npm run build:bundle && npm run build:portable",
    "build:all": "npm run build:integrated && npm run build:bundle && npm run build:portable && npm run build:docker",
    "deploy": "node scripts/deploy.js",
    "deploy:docker": "cd build-output/docker && docker-compose up -d",
    "deploy:docker:build": "npm run build:integrated && npm run build:bundle && npm run build:docker && cd build-output/docker && docker-compose up --build -d",
    "deploy:docker:stop": "cd build-output/docker && docker-compose down",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "cd frontend && npm run preview",
    "start:backend": "cd backend && npm run start",
    "clean": "rm -rf shared/dist frontend/dist backend/dist frontend/node_modules backend/node_modules shared/node_modules node_modules build-output",
    "db:reset": "rm -f database/*.db && cd backend && npm run db:migrate",
    "verify:no-banned-imports": "node scripts/verify-no-banned-imports.mjs --mode=phase1",
    "verify:no-banned-imports:phase2": "node scripts/verify-no-banned-imports.mjs --mode=phase2",
    "verify:workspace-script-aliases": "node scripts/verify-workspace-script-aliases.mjs",
    "verify:user-db-smoke": "cd backend && npm run verify:user-db-smoke",
    "verify:sqlite-pragmas": "cd backend && npm run verify:sqlite-pragmas",
    "verify:db-migration-contracts": "cd backend && npm run verify:db-migration-contracts",
    "verify:builtin-system-modules": "cd backend && npm run verify:builtin-system-modules",
    "verify:system-api-node-contracts": "cd backend && npm run verify:system-api-node-contracts",
    "verify:queue-routing-smoke": "cd backend && npm run verify:queue-routing-smoke",
    "verify:queue-wakeup-smoke": "cd backend && npm run verify:queue-wakeup-smoke",
    "verify:queue-hot-path-contracts": "cd backend && npm run verify:queue-hot-path-contracts",
    "verify:query-cache-debounce-contracts": "cd backend && npm run verify:query-cache-debounce-contracts",
    "verify:graph-comfy-artifacts": "cd backend && npm run verify:graph-comfy-artifacts",
    "verify:graph-artifact-runtime": "cd backend && npm run verify:graph-artifact-runtime",
    "verify:video-optimization": "cd backend && npm run verify:video-optimization",
    "verify:media-postprocess-visibility": "cd backend && npm run verify:media-postprocess-visibility",
    "verify:wildcard-chain-parsing": "cd backend && npm run verify:wildcard-chain-parsing",
    "verify:complex-filter-search-stats": "cd backend && npm run verify:complex-filter-search-stats",
    "verify:route-validation-foundation": "cd backend && npm run verify:route-validation-foundation",
    "verify:upload-metadata-utilities": "cd backend && npm run verify:upload-metadata-utilities",
    "verify:upload-response-contracts": "cd backend && npm run verify:upload-response-contracts",
    "verify:prompt-tag-links": "cd frontend && npm run verify:prompt-tag-links",
    "verify:prompt-weight-display-contracts": "cd frontend && npm run verify:prompt-weight-display-contracts",
    "verify:app-document-metadata-contracts": "cd frontend && npm run verify:app-document-metadata-contracts",
    "verify:prompt-list-progress-contracts": "cd frontend && npm run verify:prompt-list-progress-contracts",
    "verify:upload-result-links": "cd frontend && npm run verify:upload-result-links",
    "verify:danbooru-browser-progress-contracts": "cd frontend && npm run verify:danbooru-browser-progress-contracts",
    "verify:module-workflow-output-progress-contracts": "cd frontend && npm run verify:module-workflow-output-progress-contracts",
    "verify:settings-paged-list-progress-contracts": "cd frontend && npm run verify:settings-paged-list-progress-contracts",
    "verify:settings-folder-selection-contracts": "cd frontend && npm run verify:settings-folder-selection-contracts",
    "verify:wildcard-search-selection-contracts": "cd frontend && npm run verify:wildcard-search-selection-contracts",
    "verify:saved-graph-list-summary-contracts": "cd frontend && npm run verify:saved-graph-list-summary-contracts",
    "verify:saved-graph-list-contracts": "cd frontend && npm run verify:saved-graph-list-contracts",
    "verify:wallpaper-widget-library-search-contracts": "cd frontend && npm run verify:wallpaper-widget-library-search-contracts",
    "verify:auth-db-bootstrap": "cd backend && npm run verify:auth-db-bootstrap",
    "verify:codex-generation-contracts": "cd backend && npm run verify:codex-generation-contracts",
    "verify:module-library-grouping": "cd frontend && npm run verify:module-library-grouping",
    "verify:module-graph-execution-status-contracts": "cd frontend && npm run verify:module-graph-execution-status-contracts",
    "verify:module-graph-execution-panel-contracts": "cd frontend && npm run verify:module-graph-execution-panel-contracts",
    "verify:wallpaper-layout-contracts": "cd frontend && npm run verify:wallpaper-layout-contracts",
    "verify:wallpaper-queue-status-contracts": "cd frontend && npm run verify:wallpaper-queue-status-contracts",
    "verify:watched-folder-route-contracts": "cd backend && npm run verify:watched-folder-route-contracts",
    "verify:graph-workflow-route-contracts": "cd backend && npm run verify:graph-workflow-route-contracts",
    "verify:queue-eta-contracts": "cd backend && npm run verify:queue-eta-contracts",
    "verify:generation-queue-ui-contracts": "cd frontend && npm run verify:generation-queue-ui-contracts",
    "verify:comfy-workflow-routing-contracts": "cd frontend && npm run verify:comfy-workflow-routing-contracts",
    "verify:generation-history-feed-progress-ui-contracts": "cd frontend && npm run verify:generation-history-feed-progress-ui-contracts",
    "verify:workflow-reservations-ui-contracts": "cd frontend && npm run verify:workflow-reservations-ui-contracts",
    "verify:home-feed-progress-ui-contracts": "cd frontend && npm run verify:home-feed-progress-ui-contracts",
    "verify:group-image-feed-progress-ui-contracts": "cd frontend && npm run verify:group-image-feed-progress-ui-contracts",
    "verify:group-explorer-count-map-contracts": "cd frontend && npm run verify:group-explorer-count-map-contracts",
    "verify:graph-queue-wait-contracts": "cd backend && npm run verify:graph-queue-wait-contracts",
    "verify:image-similarity-policy-contracts": "cd frontend && npm run verify:image-similarity-policy-contracts",
    "verify:image-similarity-contracts": "cd backend && npm run verify:image-similarity-contracts",
    "verify:data-rematch-contracts": "cd backend && npm run verify:data-rematch-contracts",
    "verify:data-rematch-ui-contracts": "cd frontend && npm run verify:data-rematch-ui-contracts",
    "verify:wildcard-guest-access-contracts": "npm run verify:wildcard-guest-access-contracts --workspace conai-backend && npm run verify:wildcard-guest-access-contracts --workspace frontend",
    "verify:file-verification-route-contracts": "cd backend && npm run verify:file-verification-route-contracts",
    "verify:civitai-route-contracts": "cd backend && npm run verify:civitai-route-contracts",
    "verify:image-editor-tool-contracts": "cd frontend && npm run verify:image-editor-tool-contracts",
    "verify:image-editor-route-contracts": "cd backend && npm run verify:image-editor-route-contracts",
    "verify:image-detail-filter-preview-contracts": "cd frontend && npm run verify:image-detail-filter-preview-contracts",
    "verify:image-download-contracts": "cd frontend && npm run verify:image-download-contracts",
    "verify:image-modal-layout-contracts": "cd frontend && npm run verify:image-modal-layout-contracts",
    "verify:home-search-drawer-contracts": "cd frontend && npm run verify:home-search-drawer-contracts",
    "verify:search-suggestion-query-contracts": "cd frontend && npm run verify:search-suggestion-query-contracts",
    "verify:image-list-selection-contracts": "cd frontend && npm run verify:image-list-selection-contracts",
    "verify:image-list-modal-contracts": "cd frontend && npm run verify:image-list-modal-contracts",
    "verify:nai-reusable-assets-contracts": "cd frontend && npm run verify:nai-reusable-assets-contracts",
    "verify:thumbnail-settings-ui-contracts": "cd frontend && npm run verify:thumbnail-settings-ui-contracts",
    "verify:image-file-route-contracts": "cd backend && npm run verify:image-file-route-contracts",
    "verify:backup-source-contracts": "cd backend && npm run verify:backup-source-contracts",
    "verify:like-search-literal-contracts": "cd backend && npm run verify:like-search-literal-contracts",
    "verify:search-option-suggestion-contracts": "cd backend && npm run verify:search-option-suggestion-contracts",
    "verify:danbooru-browser-locale-contracts": "cd backend && npm run verify:danbooru-browser-locale-contracts",
    "verify:group-image-route-contracts": "cd backend && npm run verify:group-image-route-contracts",
    "verify:supported-extension-contracts": "cd backend && npm run verify:supported-extension-contracts",
    "verify:recycle-bin-deletion-contracts": "cd backend && npm run verify:recycle-bin-deletion-contracts",
    "verify:deletion-lock-contracts": "cd backend && npm run verify:deletion-lock-contracts",
    "verify:no-ui-signatures:active": "node scripts/verify-no-ui-signatures.mjs --scope=active",
    "verify:no-ui-signatures:generated": "node scripts/verify-no-ui-signatures.mjs --scope=generated",
    "verify:no-ui-signatures:full": "node scripts/verify-no-ui-signatures.mjs --scope=full",
    "verify:no-mui-deps": "node scripts/verify-no-mui-deps.mjs --mode=warn",
    "verify:no-mui-deps:strict": "node scripts/verify-no-mui-deps.mjs --mode=strict",
    "language:preprocess": "node scripts/language-preprocess.mjs",
    "verify:policy:active-source": "node scripts/verify-repository-audit-policy.mjs --category=active-source",
    "verify:policy:generated-artifact": "node scripts/verify-repository-audit-policy.mjs --category=generated-artifact",
    "verify:migration": "npm run verify:policy:active-source && npm run verify:no-banned-imports:phase2 && npm run verify:no-ui-signatures:active && npm run verify:no-mui-deps:strict",
    "verify:migration:full": "npm run verify:migration && npm run verify:policy:generated-artifact && npm run verify:no-ui-signatures:generated && npm run verify:no-ui-signatures:full",
    "i18n:check": "node scripts/i18n-check.mjs",
    "verify:thumbnail-default-settings-contracts": "cd backend && npm run verify:thumbnail-default-settings-contracts",
    "verify:module-definition-reconcile-contracts": "cd backend && npm run verify:module-definition-reconcile-contracts",
    "verify:comfy-workflow-authoring-contracts": "cd frontend && npm run verify:comfy-workflow-authoring-contracts",
    "verify:comfy-workflow-entry-contracts": "cd frontend && npm run verify:comfy-workflow-entry-contracts",
    "verify:comfy-dropdown-auto-collect-contracts": "cd frontend && npm run verify:comfy-dropdown-auto-collect-contracts",
    "verify:comfy-server-default-contracts": "cd backend && npm run verify:comfy-server-default-contracts",
    "verify:comfy-dropdown-auto-collect-api-contracts": "cd backend && npm run verify:comfy-dropdown-auto-collect-api-contracts",
    "verify:comfy-model-thumbnail-startup-cleanup": "cd backend && npm run verify:comfy-model-thumbnail-startup-cleanup",
    "verify:lora-auto-collect-contracts": "cd frontend && npm run verify:lora-auto-collect-contracts",
    "verify:module-graph-bypass-contracts": "cd frontend && npm run verify:module-graph-bypass-contracts",
    "verify:graph-workflow-bypass-contracts": "cd backend && npm run verify:graph-workflow-bypass-contracts",
    "verify:graph-final-result-promotion-contracts": "cd backend && npm run verify:graph-final-result-promotion-contracts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vercel/ncc": "^0.38.4",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.8",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fs-extra": "^11.3.4",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "exif-parser": "^0.1.12",
    "png-chunks-extract": "^1.0.0"
  }
}
