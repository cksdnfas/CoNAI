# Core server settings
PORT=1666
NODE_ENV=development
LOCALE=en

# Network binding
# 0.0.0.0 = listen on all interfaces, localhost = local-only
BIND_ADDRESS=0.0.0.0
FRONTEND_URL=http://localhost:1677
ENABLE_EXTERNAL_IP=false

# Runtime data root
RUNTIME_BASE_PATH=./user
# Optional per-folder overrides
# RUNTIME_UPLOADS_DIR=E:/CoNAI/uploads
# RUNTIME_DATABASE_DIR=E:/CoNAI/database
# RUNTIME_LOGS_DIR=E:/CoNAI/logs
# RUNTIME_TEMP_DIR=E:/CoNAI/temp
# RUNTIME_MODELS_DIR=E:/CoNAI/models
# RUNTIME_RECYCLE_BIN_DIR=E:/CoNAI/RecycleBin

# Optional public URL hints
# BACKEND_PROTOCOL=https
# BACKEND_HOST=example.com
# PUBLIC_BASE_URL=https://example.com:1666
# BACKEND_ORIGIN=https://example.com:1666
# PUBLIC_HOST=example.com

# Session secret
# If omitted, CoNAI generates and persists a local runtime secret automatically.
# SESSION_SECRET=replace-with-a-long-random-string

# Optional diagnostics
# SAFE_SMOKE_MODE=true
