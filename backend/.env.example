# 서버 설정
PORT=1566
NODE_ENV=development

# 프론트엔드 URL (Vite 개발서버 포트)
FRONTEND_URL=http://localhost:1577

# 데이터베이스 설정
DATABASE_PATH=../database/images.db

# 업로드 설정
UPLOAD_PATH=../uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif,image/bmp,image/tiff

# 보안 설정
JWT_SECRET=comfyui-image-manager-secret-2024
CORS_ORIGIN=http://localhost:1577

# 로깅 설정
LOG_LEVEL=info
LOG_FILE=logs/app.log