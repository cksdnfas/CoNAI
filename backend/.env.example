# 서버 설정
PORT=1566
NODE_ENV=development

# 네트워크 바인딩 설정
# 0.0.0.0 = 모든 네트워크 인터페이스에서 접근 가능 (기본값, 권장)
# localhost = 로컬 컴퓨터에서만 접근 가능
BIND_ADDRESS=0.0.0.0

# 외부 IP 감지 활성화 (네트워크 접속 정보 표시용)
ENABLE_EXTERNAL_IP=false

# 프론트엔드 URL (Vite 개발서버 포트)
FRONTEND_URL=http://localhost:1577

# 데이터베이스 설정
DATABASE_PATH=../database/images.db

# 업로드 설정
UPLOAD_PATH=../uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif,image/bmp,image/tiff

# 보안 설정
JWT_SECRET=comfyui-image-manager-secret-2024
CORS_ORIGIN=http://localhost:1577

# 인증 설정
# Session secret for express-session (generate a random string for production)
SESSION_SECRET=your-session-secret-change-this-in-production

# 로깅 설정
LOG_LEVEL=info
LOG_FILE=logs/app.log

# WD v3 Tagger Settings
# Note: Tagger settings are managed via Settings UI (config/settings.json)
# The values below are only used as initial defaults on first run
# After first run, all tagger settings should be changed through Settings page