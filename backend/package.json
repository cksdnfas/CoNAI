{
  "name": "comfyui-image-manager-backend",
  "version": "1.0.1",
  "description": "Backend API server for ComfyUI Image Manager",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run copy:migrations",
    "copy:migrations": "copyfiles -u 1 \"src/database/migrations/**/*.sql\" dist/",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/database/migrate.ts"
  },
  "dependencies": {
    "@comfyui-image-manager/shared": "file:../shared",
    "adm-zip": "^0.5.16",
    "argon2": "^0.44.0",
    "axios": "^1.12.2",
    "better-sqlite3": "^9.4.0",
    "blake2": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "form-data": "^4.0.4",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "selfsigned": "^3.0.1",
    "sharp": "^0.33.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.2.1",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.21",
    "@types/uuid": "^10.0.0",
    "copyfiles": "^2.4.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
