{
  "name": "conai-backend",
  "version": "26.3.14",
  "description": "Backend API server for CoNAI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --ignore 'database/**' --ignore 'uploads/**' --ignore '**/*.db' --signal SIGTERM --exec tsx src/index.ts",
    "build": "tsc && npm run copy:migrations",
    "copy:migrations": "copyfiles -u 1 \"src/database/migrations/**/*.sql\" dist/",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/database/migrate.ts"
  },
  "dependencies": {
    "@conai/shared": "file:../shared",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node-cron": "^3.0.11",
    "adm-zip": "^0.5.16",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "better-queue": "^3.8.12",
    "better-sqlite3": "^12.8.0",
    "better-sqlite3-session-store": "^0.1.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "fast-glob": "^3.3.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "form-data": "^4.0.4",
    "helmet": "^8.1.0",
    "lru-cache": "^11.2.7",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "selfsigned": "^5.5.0",
    "sharp": "^0.34.5",
    "sharp-phash": "^2.2.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "^2.8.17",
    "@types/express-session": "^1.18.2",
    "@types/form-data": "^2.2.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/uuid": "^10.0.0",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
